const GEMINI_API_KEY = 'AIzaSyArubthp6d1_hM09ZAiXUA_Norno7Mwz5o';
const GEMINI_MODEL   = 'gemini-2.5-flash';
const C = {NAME:1,GRADE:2,GENDER:3,KEYWORDS:4,MESSAGE:5,SENT:6,HISTORY:7};

// ═══ API 엔드포인트 ═══
function doGet(e){
  var action = (e && e.parameter && e.parameter.action) || '';
  var result;
  try {
    if(action === 'loadStudents'){
      result = {ok:true, data:loadStudents()};
    } else {
      result = {ok:false, error:'Unknown action: '+action};
    }
  } catch(err){
    result = {ok:false, error:err.message};
  }
  return _json(result);
}

function doPost(e){
  var body = JSON.parse(e.postData.contents);
  var action = body.action || '';
  var result;
  try {
    if(action === 'saveKeywords'){
      result = {ok:true, data:saveKeywords(body.updates)};
    } else if(action === 'saveMessage'){
      result = {ok:true, data:saveMessage(body.row, body.text)};
    } else if(action === 'generateKakao'){
      result = {ok:true, data:generateKakao(body.name, body.gg, body.kw, body.hist)};
    } else if(action === 'markDone'){
      result = {ok:true, data:markDone(body.row, body.text)};
    } else if(action === 'undoDone'){
      result = {ok:true, data:undoDone(body.row)};
    } else {
      result = {ok:false, error:'Unknown action: '+action};
    }
  } catch(err){
    result = {ok:false, error:err.message};
  }
  return _json(result);
}

function _json(obj){
  return ContentService.createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}

// ═══ 기존 로직 (변경 없음) ═══
function _ws(){return SpreadsheetApp.getActiveSpreadsheet().getSheets()[0]}
function _cm(){return Utilities.formatDate(new Date(),'Asia/Seoul','yyyy-MM')}

function loadStudents(){
  var ws=_ws(),data=ws.getDataRange().getValues(),cm=_cm(),r=[];
  for(var i=1;i<data.length;i++){
    var d=data[i],name=String(d[0]||'').trim();
    if(!name)continue;
    var grade=String(d[1]||'').trim(),gender=String(d[2]||'').trim();
    var kw=String(d[3]||'').trim(),msg=String(d[4]||'').trim();
    var rawSent=d[5]||'';
    var sent=(rawSent instanceof Date)?Utilities.formatDate(rawSent,'Asia/Seoul','yyyy-MM'):String(rawSent).trim();
    var hist=String(d[6]||'').trim();
    var isDone=sent===cm;
    r.push({row:i+1,name:name,grade:grade,gender:gender,
      gg:[grade,gender].filter(Boolean).join(' '),
      kw:isDone?kw:'',prevKw:kw,
      msg:msg,hist:hist,done:isDone});
  }
  return r;
}

function saveKeywords(updates){
  var ws=_ws();
  for(var i=0;i<updates.length;i++)ws.getRange(updates[i].row,C.KEYWORDS).setValue(updates[i].kw);
  return true;
}

function saveMessage(row,text){
  _ws().getRange(row,C.MESSAGE).setValue(text);
  return true;
}

function generateKakao(name,gg,kw,hist){
  var histBlock=(hist&&hist.trim())?hist:'이전 이력 없음';
  var prompt=_sysPrompt()+
    '\n\n학생 이름: '+name+'\n학년/성별: '+gg+'\n이번 달 키워드: '+kw+
    '\n\n## 과거 메시지 (아래 표현/칭찬/문장구조와 겹치지 않게 새롭게 쓸 것)\n'+histBlock+
    '\n\n위 정보로 학부모 카톡 메시지를 작성하세요. 300~500자, 마무리 인사(감사드립니다^^)까지 완성. 과거 메시지와 표현이 겹치지 않게 자연스럽게 새로운 표현을 사용하세요.';
  var result=_gemini(prompt,0.7,4000);
  if(result.text.length<250||result.reason==='MAX_TOKENS'){
    var retry=_gemini(prompt,0.7,4000);
    if(retry.text.length>result.text.length)result=retry;
  }
  if(result.text.length<250)return '[SHORT]'+result.text;
  return result.text;
}

function markDone(row,text){
  var ws=_ws(),cm=_cm();
  ws.getRange(row,C.MESSAGE).setValue(text);
  ws.getRange(row,C.SENT).setValue(cm);
  var h=String(ws.getRange(row,C.HISTORY).getValue()||'');
  var entries=h.split('|||').map(function(x){return x.trim()}).filter(Boolean);
  entries.push('['+cm+'] '+text);
  while(entries.length>3)entries.shift();
  ws.getRange(row,C.HISTORY).setValue(entries.join(' ||| '));
  return true;
}

function undoDone(row){
  var ws=_ws();
  ws.getRange(row,C.SENT).setValue('');
  var h=String(ws.getRange(row,C.HISTORY).getValue()||'');
  var entries=h.split('|||').map(function(x){return x.trim()}).filter(Boolean);
  if(entries.length>0)entries.pop();
  ws.getRange(row,C.HISTORY).setValue(entries.join(' ||| '));
  return true;
}

function _gemini(prompt,temp,max){
  var url='https://generativelanguage.googleapis.com/v1beta/models/'+GEMINI_MODEL+':generateContent?key='+GEMINI_API_KEY;
  var res=UrlFetchApp.fetch(url,{method:'post',contentType:'application/json',
    payload:JSON.stringify({contents:[{parts:[{text:prompt}]}],generationConfig:{temperature:temp,maxOutputTokens:max}}),
    muteHttpExceptions:true});
  var j=JSON.parse(res.getContentText());
  if(j.candidates&&j.candidates[0]&&j.candidates[0].content)
    return{text:j.candidates[0].content.parts[0].text.trim(),reason:j.candidates[0].finishReason||'STOP'};
  throw new Error('Gemini: '+res.getContentText().substring(0,100));
}

function _sysPrompt(){
  return '당신은 소리마을 음악교습소 원장님의 카카오톡 메시지를 대필하는 AI입니다.\n\n## 핵심\n- 300~500자 분량\n- "안녕하세요 소리마을입니다 🎵"로 시작\n- "~이 진도상황 안내드릴게요~^^"\n- ~요 체, ^^, ㅎㅎ 자연스럽게\n- 장점→보완점→격려→마무리 순서\n- 반드시 마무리 인사로 끝낼 것 (감사드립니다^^)\n\n## 중복 방지\n- 과거 메시지의 칭찬 표현, 격려 패턴, 문장 구조를 반복하지 마세요\n- 자연스럽게 매달 새로운 표현을 사용하세요\n\n## 레퍼런스 1\n안녕하세요 소리마을입니다 🎵\n하온이 진도상황 안내드릴게요~^^\n하온이는 현재 바이엘 2권의 7번에서 오른손 가운데 도와 솔, 왼손 낮은 파의 제이름을 잊을 수 있도록 반복해서 연습하고 있어요~ 손가락을 세워서 치는 게 손목과 손가락이 불편할 수 있는데 가르쳐주는대로 쏙쏙 흡수해서 잘 받아들이고 있어요~\n나중이 더 기대되는 아이랍니다 ㅎㅎ\n다른 음을 칠 때 이전에 지던 손가락을 잘 떼어줘야 소리가 깨끗하게 나는데, 소리가 섞이는 경우가 종종 있어요~ 손 모양을 신경쓰다 보니 손가락을 높이 들지 못해서 그런거라 조금 더 익숙해지고 나면 손가락을 들어서 깔끔하게 누를 수 있을거예요 ㅎㅎ\n연습을 열심히 하는 모습이 예뻐서 영상으로 짧게 남겨봤어요~ 다음달에는 선생님이랑 함께 포핸즈 곡을 준비해서 촬영해보려고 해요^^\n함께 더 풍부한 소리를 들으며 연주할 수 있어서 재미도 있고 성취감을 느낄 수 있답니다^^\n\n## 레퍼런스 2\n안녕하세요 소리마을입니다 🎵\n한경이 진도상황 안내드릴게요~^^\n한경이는 피아노 시작한 지 얼마 안 된 걸로 아는데 벌써 바이엘 4권의 51번까지 배웠어요~ 라장조에서 파도에 #을 붙려주며 화성을 느끼도록 연습하고 있어요~ 보통 아이들은 조표를 지켜서 치는 걸 어려워하는데 한경이는 처음 인지하고 나면 스스로 잘 지키더라구요 ㅎㅎ\n반주도 이제 3화음을 코드로 누르는 연습을 하고 있어요~ 영어 음이름을 반주 시작하면서 처음 배웠는데 계속 잘 기억하고 있더라구요^^ 제이름을 공부할 때 영어 음이름도 병행하며 익히고 있답니다^^\n\n## 레퍼런스 3\n안녕하세요 소리마을입니다 🎵\n주현이랑 주호 진도상황 안내드릴게요~^^\n주현이는 현재 체르니 100의 19번에서 뒷꿈을 정확히 읽으며 쉴 수 있도록 연습하고 있어요~ 리듬도 잘 지키고 연습을 착실히 잘 해줘서 수업을 항상 잘 따라와주고 있답니다^^ 곡의 흐름을 넓게 이해하고 길게 노래할 수 있도록 생각해주며 연습하면 더 완성도있게 연주할 수 있을 것 같아요~\n주현이가 새끼손가락이 다른 손가락에 비해 약간 짧은 편이라 5번-4번 손가락을 연결하는 걸 어려워하는데 최대한 세워서 치며 떨어지지 않도록 계속 훈련하고 있답니다 ㅎㅎ\n주호는 바이엘 2권의 36번에서 3도 도약을 건너뛰어 누르는 연습을 하고 있어요~ 이제 쓰여있는 손가락번호를 지우고 스스로 제이름을 읽고 칠 수 있도록 지도하고 있답니다 ㅎㅎ 아무지게 열심히 연습하는 모습이 너무 예뻐요 ☺\n늘 아이를 믿고 맡겨주셔서 감사드립니다 앞으로도 정성껏 지도하겠습니다^^\n\n## 규칙\n1. 레퍼런스 말투 따를 것\n2. 교재명/곡번호는 키워드 것만\n3. 지어내지 말 것\n4. 300~500자\n5. 마무리 인사까지 완성\n6. 과거 메시지와 표현 겹치지 않게';
}

function setupSheet(){
  var ws=_ws();
  var data=ws.getDataRange().getValues();
  var headers=['이름','학년','성별','키워드','카톡메시지','발송월','이력'];
  if(data.length===0||String(data[0][0]).trim()!=='이름'){
    ws.getRange(1,1,1,7).setValues([headers]);
  }
  if(data.length<=1){
    var s=[['강건우','초2','남'],['김라은','초2','여'],['김수지','초5','여'],['김연정','초2','여'],['김이현','초2','남'],['김하은','초1','여'],['박주은','초6','여'],['배해준','중2','남'],['석준하','초4','남'],['선주현','초4','남'],['선주호','초2','남'],['송에린','초1','여'],['송이든','초5','남'],['유채은','초3','여'],['이다은','초5','여'],['이원재','초5','남'],['이채민','초2','여'],['이하리','초4','여'],['이한경','초5','여'],['장시온','초5','남'],['장하온','초2','남'],['홍라경','초3','여'],['홍예진','초2','여']];
    ws.getRange(2,1,s.length,7).setValues(s.map(function(r){return[r[0],r[1],r[2],'','','','']}));
  }
  return 'done';
}
